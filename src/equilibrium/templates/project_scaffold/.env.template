# Equilibrium Environment Configuration
# ======================================
# All settings are commented out by default. Uncomment and modify as needed.
#
# Environment variables override default settings from:
# 1. Built-in defaults (platformdirs locations)
# 2. User config file (~/.config/EQUILIBRIUM/config.toml)
# 3. These .env settings (highest precedence)

# Directory Configuration
# -----------------------
# Override default data directory (default: ~/.local/share/EQUILIBRIUM/)
# EQUILIBRIUM_PATHS__DATA_DIR=~/my_equilibrium_data

# Override individual subdirectories (default: subdirs of DATA_DIR)
# EQUILIBRIUM_PATHS__SAVE_DIR=~/my_equilibrium_data/cache
# EQUILIBRIUM_PATHS__LOG_DIR=~/my_equilibrium_data/logs
# EQUILIBRIUM_PATHS__DEBUG_DIR=~/my_equilibrium_data/debug
# EQUILIBRIUM_PATHS__PLOT_DIR=~/my_equilibrium_data/plots

# Logging Configuration
# ---------------------
# Enable logging (default: false)
# EQUILIBRIUM_LOGGING__ENABLED=true

# Set logging level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# EQUILIBRIUM_LOGGING__LEVEL=DEBUG

# Log to console (default: true)
# EQUILIBRIUM_LOGGING__CONSOLE=true

# Log to file (default: true when logging enabled)
# EQUILIBRIUM_LOGGING__FILE=true

# Log filename pattern (default: equilibrium_{date}.log)
# {date} is replaced with YYYYMMDD
# EQUILIBRIUM_LOGGING__FILENAME_PATTERN=equilibrium_{date}.log

# Maximum log file size before rotation in bytes (default: 10485760 = 10MB)
# EQUILIBRIUM_LOGGING__MAX_BYTES=10485760

# Number of backup log files to keep (default: 5)
# EQUILIBRIUM_LOGGING__BACKUP_COUNT=5

# Log rotation type (default: size)
# Options: size, time
# EQUILIBRIUM_LOGGING__ROTATION_TYPE=size

# Time-based rotation settings (when ROTATION_TYPE=time)
# EQUILIBRIUM_LOGGING__TIME_WHEN=midnight
# EQUILIBRIUM_LOGGING__TIME_INTERVAL=1

# General Settings
# ----------------
# Enable verbose output (default: false)
# EQUILIBRIUM_VERBOSE=false

# Set random seed for reproducibility (default: None)
# EQUILIBRIUM_SEED=42

# User config file location (default: ~/.config/EQUILIBRIUM/config.toml)
# EQUILIBRIUM_CONFIG_FILE=~/.config/EQUILIBRIUM/config.toml

# JAX Configuration
# -----------------
# Compute platform (default: cpu). Use "gpu" or "tpu" to use accelerators,
# or leave blank to let JAX auto-detect available hardware.
# EQUILIBRIUM_JAX__PLATFORM=cpu

# Enable JAX compilation logging for debugging
# JAX_LOG_COMPILES=1

# Prevent JAX from preallocating GPU memory
# Useful when sharing a GPU with other processes
# XLA_PYTHON_CLIENT_PREALLOCATE=false

# Enable 64-bit precision (also controlled by EQUILIBRIUM_JAX__ENABLE_X64)
# JAX_ENABLE_X64=true
